# General settings
markup=1
actions=1
sort=-time
layer=overlay
anchor=top-right
max-visible=5

# Format
font=Geist 12
width=400
height=100
margin=10
padding=15
border-size=2
border-radius=5

# Colors from theme
background-color=#F3ECE3F2
text-color=#2C2622
border-color=#D8C8B7
progress-color=#D66A52

# Format
format=<b>%s</b> <span color="#7D7268">(%a)</span>\n%b

# Icons
icons=true

# Interaction
on-button-left=invoke-default-action
on-button-middle=dismiss-all
on-button-right=dismiss
on-touch=dismiss

# Timeout settings (in milliseconds)
default-timeout=5000

# History
max-history=10
history=1

# Hidden format
[hidden]
format=Hidden: %h [%t]

# Urgency levels
[urgency=low]
text-color=#7D7268
default-timeout=10000

[urgency=low actionable]
border-color=#C9B7A5

[urgency=normal actionable]
border-color=#D66A52

[urgency=high]
border-color=#C75A44
default-timeout=0

[urgency=high actionable]
border-color=#D66A52

# Group settings
group-by=app-name,summary

[grouped]
format=(%g) <b>%s</b>\n%b
