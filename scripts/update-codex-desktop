#!/usr/bin/env bash

set -euo pipefail

readonly repo_url="https://github.com/ilysenko/codex-desktop-linux.git"
readonly repo_branch="main"
readonly checkout_dir="${XDG_CACHE_HOME:-$HOME/.cache}/codex-desktop-linux/source"
readonly package_cache="${XDG_CACHE_HOME:-$HOME/.cache}/codex-desktop/packages"
readonly updater_cache="${XDG_CACHE_HOME:-$HOME/.cache}/codex-update-manager/downloads"
readonly build_info="/opt/codex-desktop/resources/codex-linux-build-info.json"
readonly feature_config="/home/oli/dotfiles/.config/codex-desktop-linux/features.json"
readonly app_pid_file="${XDG_STATE_HOME:-$HOME/.local/state}/codex-desktop/app.pid"

if [[ ! -r "$build_info" ]]; then
  printf '%s\n' "Codex Desktop wrapper metadata is unavailable; skipping its update."
  exit 0
fi

installed_commit="$(jq -r '.source.commit // empty' "$build_info")"
remote_commit="$(git ls-remote "$repo_url" "refs/heads/$repo_branch" | awk 'NR == 1 { print $1 }')"

if [[ -z "$remote_commit" ]]; then
  printf '%s\n' "Could not check the Codex Desktop Linux wrapper; skipping its update." >&2
  exit 0
fi

app_is_running() {
  local pid=""

  [[ -r "$app_pid_file" ]] || return 1
  read -r pid < "$app_pid_file" || return 1
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

cached_package_for_commit() {
  local package="" package_commit=""

  [[ -d "$package_cache" ]] || return 1
  while IFS= read -r -d '' package; do
    package_commit="$(
      bsdtar -xOf "$package" opt/codex-desktop/resources/codex-linux-build-info.json 2>/dev/null |
        jq -r '.source.commit // empty' 2>/dev/null || true
    )"
    if [[ "$package_commit" == "$remote_commit" ]]; then
      printf '%s\n' "$package"
      return 0
    fi
  done < <(find "$package_cache" -maxdepth 1 -type f -name 'codex-desktop-*.pkg.tar.zst' -print0)

  return 1
}

latest_cached_dmg() {
  local dmg=""

  [[ -d "$updater_cache" ]] || return 1
  dmg="$(find "$updater_cache" -maxdepth 1 -type f -name '*.dmg' -printf '%T@ %p\n' |
    sort -nr | head -n 1 | cut -d' ' -f2-)"
  [[ -n "$dmg" ]] || return 1
  printf '%s\n' "$dmg"
}

if [[ "$installed_commit" != "$remote_commit" ]]; then
  if app_is_running; then
    printf '%s\n' "Codex Desktop has a Linux wrapper update. Close it and rerun 'up' to install it."
    exit 0
  fi

  if package="$(cached_package_for_commit)"; then
    printf '%s\n' "Installing verified Codex Desktop Linux package: $package"
    sudo pacman -U --needed --noconfirm "$package"
  else
    if [[ -d "$checkout_dir/.git" ]]; then
      git -C "$checkout_dir" pull --ff-only origin "$repo_branch"
    elif [[ -e "$checkout_dir" ]]; then
      printf '%s\n' "Codex wrapper cache exists but is not a Git checkout: $checkout_dir" >&2
      exit 1
    else
      mkdir -p "$(dirname "$checkout_dir")"
      git clone --branch "$repo_branch" --single-branch "$repo_url" "$checkout_dir"
    fi

    build_args=(install-native)
    if dmg="$(latest_cached_dmg)"; then
      build_args+=("DMG=$dmg")
    fi

    printf '%s\n' "Building the updated Codex Desktop Linux wrapper."
    CODEX_LINUX_ENABLE_COMPUTER_USE_UI=1 \
      CODEX_LINUX_FEATURES_CONFIG="$feature_config" \
      MAX_BUILD_THREADS="$(nproc)" \
      make -C "$checkout_dir" "${build_args[@]}"
  fi
fi

if command -v codex-update-manager >/dev/null 2>&1; then
  codex-update-manager check-now
  codex-update-manager install-ready
fi
