[help]
on = {{ fg = "{status['blue']}" }}
run = {{ fg = "{accent}" }}
hovered = {{ reversed = true, bold = true }}
footer = {{ fg = "{accent_fg}", bg = "{accent}" }}

[spot]
border = {{ fg = "{colors['borders']['focus']}" }}
