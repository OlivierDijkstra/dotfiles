[Unit]
Description=Dynamic Island
Wants=graphical-session.target
After=graphical-session.target
PartOf=graphical-session.target
ConditionPathExists=%h/dotfiles/.config/dynamic-island/shell.qml

[Service]
Type=simple
ExecStart=%h/dotfiles/scripts/dynamic-island-launch
Restart=on-failure
RestartSec=2
Slice=session.slice

[Install]
WantedBy=default.target
