tbl_col = {{ fg = "{status['blue']}" }}
tbl_cell = {{ fg = "{text['primary']}", bg = "{selected}" }}

[notify]
title_info = {{ fg = "{status['blue']}" }}
title_warn = {{ fg = "{status['yellow']}" }}
title_error = {{ fg = "{status['red']}" }}

[filetype]
rules = [
  {{ mime = "image/*", fg = "{status['magenta']}" }},
  {{ mime = "{{audio,video}}/*", fg = "{status['yellow']}" }},
  {{ mime = "application/{{zip,rar,7z*,tar,gzip,xz,zstd,bzip*,lzma,compress,archive,cpio,arj,xar,ms-cab*}}", fg = "{status['red']}" }},
  {{ mime = "application/{{pdf,doc,rtf}}", fg = "{status['green']}" }},
  {{ mime = "vfs/{{absent,stale}}", fg = "{text['muted']}" }},
  {{ url = "*", fg = "{text['primary']}" }},
  {{ url = "*/", fg = "{status['blue']}" }},
]
'''


def rofi_colors(colors: dict) -> str:
    return f'''/* {GENERATED_NOTE} */
* {{
    bg0: {rgba(colors['surfaces'][0], 0.96)};
    bg1: {rgba(colors['surfaces'][1], 1)};
    bg2: {rgba(colors['interaction']['hover'], 1)};
    bg3: {rgba(colors['interaction']['selected'], 1)};
    fg0: {rgba(colors['text']['primary'], 1)};
    fg1: {rgba(colors['text']['secondary'], 1)};
    fg2: {rgba(colors['text']['muted'], 1)};
    fg3: {rgba(colors['text']['disabled'], 1)};
    border0: {rgba(colors['borders']['default'], 1)};
    border1: {rgba(colors['borders']['strong'], 1)};
    accent: {rgba(colors['accent']['default'], 1)};
    accent-fg: {rgba(colors['accent']['foreground'], 1)};
}}
'''


def mako_config(palette: dict) -> str:
    def mode_section(mode: str) -> str:
        colors = palette[mode]
        return f'''[mode={mode}]
background-color={alpha(colors['surfaces'][2], 'F2')}
text-color={colors['text']['primary']}
border-color={colors['borders']['default']}
progress-color={colors['accent']['default']}'''

    return f'''# {GENERATED_NOTE}
markup=1
actions=1
sort=-time
layer=overlay
anchor=top-right
max-visible=5
font=Geist 12
width=400
height=100
margin=10
padding=15
border-size=1
border-radius=14
format=<b>%s</b> (%a)\\n%b
icons=true
on-button-left=invoke-default-action
on-button-middle=dismiss-all
on-button-right=dismiss
on-touch=dismiss
default-timeout=5000
max-history=10
history=1
group-by=app-name,summary

{mode_section('light')}

{mode_section('dark')}

[hidden]
format=Hidden: %h [%t]

[urgency=low]
default-timeout=10000

[mode=light urgency=high]
border-color={palette['light']['status']['red']}
default-timeout=0

[mode=dark urgency=high]
border-color={palette['dark']['status']['red']}
default-timeout=0

[grouped]
format=(%g) <b>%s</b>\\n%b
'''


def color_conf(colors: dict) -> str:
    return "\n".join(
        [
            f"# {GENERATED_NOTE}",
            f"$active = rgb({colors['accent']['default'][1:]})",
            f"$activeAlt = rgb({colors['interaction']['selected'][1:]})",
            f"$background = rgb({colors['surfaces'][0][1:]})",
            f"$backgroundAlt = rgb({colors['surfaces'][1][1:]})",
        ]
    ) + "\n"


def outputs(palette: dict) -> dict[Path, str]:
    generated = {
        ROOT / ".config/theme/colors.css": generated_css(palette),
        ROOT / ".config/theme/colors-light.conf": color_conf(palette["light"]),
        ROOT / ".config/theme/colors-dark.conf": color_conf(palette["dark"]),
        ROOT / ".config/hypr/config/palette.lua": hypr_palette(palette),
        ROOT / ".config/dynamic-island/components/Palette.qml": quickshell_palette(palette),
        ROOT / ".config/mako/config": mako_config(palette),
    }
    for mode in ("light", "dark"):
        colors = palette[mode]
        ghostty_name = "os1" if mode == "light" else "os1-night"
        btop_name = "os1.theme" if mode == "light" else "os1-night.theme"
        vicinae_name = "os1.toml" if mode == "light" else "os1-night.toml"
        yazi_name = "os1-light.yazi" if mode == "light" else "os1-dark.yazi"
        generated[ROOT / f".config/ghostty/themes/{ghostty_name}"] = ghostty_theme(mode, colors)
        generated[ROOT / f".config/btop/themes/{btop_name}"] = btop_theme(colors)
        generated[ROOT / f".local/share/vicinae/themes/{vicinae_name}"] = vicinae_theme(mode, colors)
        generated[ROOT / f".config/yazi/flavors/{yazi_name}/flavor.toml"] = yazi_theme(colors)
        generated[ROOT / f".config/rofi/colors-{mode}.rasi"] = rofi_colors(colors)
    return generated


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--check", action="store_true", help="fail when generated files are stale")
    args = parser.parse_args()
    palette = load_palette()
    stale = []
    for path, content in outputs(palette).items():
        if not path.exists() or path.read_text() != content:
            stale.append(path)
            if not args.check:
                path.parent.mkdir(parents=True, exist_ok=True)
                path.write_text(content)
    if args.check and stale:
        for path in stale:
            print(path.relative_to(ROOT), file=sys.stderr)
        return 1
    if not args.check:
        print(f"generated {len(outputs(palette))} theme files")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
