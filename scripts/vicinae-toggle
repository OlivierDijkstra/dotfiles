#!/usr/bin/env bash
set -euo pipefail

VICINAE_BIN="/usr/bin/vicinae"

if ! "$VICINAE_BIN" ping >/dev/null 2>&1; then
  "$VICINAE_BIN" server --replace >/dev/null 2>&1 &
  for _ in $(seq 1 40); do
    sleep 0.05
    if "$VICINAE_BIN" ping >/dev/null 2>&1; then
      break
    fi
  done
fi

exec "$VICINAE_BIN" toggle
