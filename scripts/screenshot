#!/usr/bin/env zsh

# Region screenshot to clipboard using grim and slurp
# Handles cancellation gracefully

REGION=$(slurp 2>/dev/null)

if [[ -z "$REGION" ]]; then
    notify-send "Screenshot" "Selection cancelled" -t 2000
    exit 0
fi

grim -g "$REGION" - | wl-copy
notify-send "Screenshot" "Copied to clipboard" -t 2000
