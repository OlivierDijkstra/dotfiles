#!/usr/bin/env zsh

# Toggle screen recording using gpu-screen-recorder
# Press once to select region and start, press again to stop
# Saves to ~/Videos/Recordings/

RECORDING_DIR="$HOME/Videos/Recordings"
PIDFILE="/tmp/screenrecord.pid"
PATHFILE="/tmp/screenrecord.path"

# Check if already recording
if [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    # Stop recording (SIGINT for proper file finalization)
    kill -SIGINT "$(cat "$PIDFILE")"
    sleep 0.5
    OUTPUT_FILE="$(cat "$PATHFILE")"
    rm -f "$PIDFILE" "$PATHFILE"
    notify-send "Screen Recording" "Recording saved" -t 2000
    xdg-open "$OUTPUT_FILE" &
    exit 0
fi

# Start new recording
mkdir -p "$RECORDING_DIR"
OUTPUT_FILE="$RECORDING_DIR/recording-$(date +%Y%m%d-%H%M%S).mp4"

# Select region with slurp (outputs "X,Y WxH")
SLURP_OUT=$(slurp 2>/dev/null)

# Check if user cancelled
if [[ -z "$SLURP_OUT" ]]; then
    notify-send "Screen Recording" "Selection cancelled" -t 2000
    exit 0
fi

# Convert slurp format "X,Y WxH" to gpu-screen-recorder format "WxH+X+Y"
X=$(echo "$SLURP_OUT" | cut -d',' -f1)
Y=$(echo "$SLURP_OUT" | cut -d',' -f2 | cut -d' ' -f1)
WH=$(echo "$SLURP_OUT" | cut -d' ' -f2)
REGION="${WH}+${X}+${Y}"

# Start recording in background
notify-send "Screen Recording" "Recording started..." -t 2000
gpu-screen-recorder -w region -region "$REGION" -f 60 -k h264 -q very_high -o "$OUTPUT_FILE" &
echo $! > "$PIDFILE"
echo "$OUTPUT_FILE" > "$PATHFILE"
